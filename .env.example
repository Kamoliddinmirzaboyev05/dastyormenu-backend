# ---- Django core ----
# REQUIRED in production. Generate: python scripts/generate_secret_key.py
SECRET_KEY=your-secret-key-here
DEBUG=False
# REQUIRED in production (comma-separated, no scheme)
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app
# Entry points default to production; override locally for dev tooling.
DJANGO_SETTINGS_MODULE=config.settings.production

# Public URL of the CUSTOMER menu app — used to build QR links (no trailing slash)
FRONTEND_MENU_URL=https://menu.dastyor.uz

# ---- Auth / JWT ----
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=30
# httpOnly refresh cookie. For cross-site SPA<->API use SameSite=None + Secure.
AUTH_COOKIE_SECURE=True
AUTH_COOKIE_SAMESITE=None
# Optional: scope cookie to a parent domain (e.g. .dastyor.uz)
AUTH_COOKIE_DOMAIN=

# First superuser (created by `manage.py create_admin`). Min 10 chars, or skipped.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@dastyor.uz
ADMIN_PASSWORD=

# ---- Database (Railway sets DATABASE_URL automatically) ----
DATABASE_URL=
DB_NAME=dastyor_db
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ---- Redis (Channels + Celery) ----
REDIS_HOST=localhost
REDIS_PORT=6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ---- CORS / CSRF (explicit allowlist — NEVER allow-all) ----
# Comma-separated origins of the admin panel + client app.
CORS_ALLOWED_ORIGINS=https://admin.dastyor.uz,https://menu.dastyor.uz
CSRF_TRUSTED_ORIGINS=https://admin.dastyor.uz,https://menu.dastyor.uz

# ---- Security ----
SECURE_SSL_REDIRECT=False

# ---- Image hosting ----
# Get a fresh key at https://api.imgbb.com — ROTATE if it was ever committed.
IMGBB_API_KEY=your-imgbb-api-key

# ---- S3 / MinIO (optional, alternative to ImgBB) ----
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=dastyor-media
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=us-east-1
